{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "types": ["vite/client"]
  },
  "include": ["*.ts", "env.d.ts"]
}
